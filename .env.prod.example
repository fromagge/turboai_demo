# TurboAI — production env example for bare metal (docker compose prod)
# Copy to .env and fill in real values. Never commit .env.

# --- Django ---
DEBUG=False
SECRET_KEY=generate-a-50-char-random-secret-key-for-production
# Comma-separated: add your domain(s) and IP(s) users will use to reach the app
ALLOWED_HOSTS=localhost,127.0.0.1,web

# --- CORS & CSRF (frontend origin) ---
# Comma-separated origins the browser will use (e.g. https://your-domain.com)
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# --- Postgres (used by docker-compose.deps + overridden for web service) ---
PGHOST=localhost
PGPORT=5432
PGDATABASE=turboai
PGUSER=turboai
PGPASSWORD=set-a-strong-postgres-password

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# Optional: REDIS_PASSWORD= if Redis is configured with requirepass
# Optional: REDIS_URL=redis://[:password]@host:port/db (overrides host/port/db)

# --- Frontend (optional; compose sets BACKEND_URL=http://web:8000 when using docker-compose.prod) ---
# BACKEND_URL=http://web:8000
