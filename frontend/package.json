    "@tiptap/starter-kit": "^3.20.1",
    "@types/turndown": "^5.0.6",
    "clsx": "^2.1.1",
    "immer": "^11.1.4",
    "marked": "^17.0.4",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^10.1.0",
    "sonner": "^2.0.7",
